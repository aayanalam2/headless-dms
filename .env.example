# ============================================================
# Document Management API — Environment Variables
# Copy this file to .env and fill in values for local development.
# NEVER commit .env to source control.
# ============================================================

# ---- Database -----------------------------------------------
# Local dev (matches docker-compose.yml):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/document_management

# ---- JWT Auth -----------------------------------------------
# Secret used to sign and verify JWTs. Must be at least 32 chars in production.
JWT_SECRET=change-me-in-production-use-a-long-random-string

# ---- S3-compatible Object Storage ---------------------------
# MinIO (local dev):
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=documents
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# AWS S3 (production example):
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ---- Server --------------------------------------------------
PORT=3000
NODE_ENV=development

# ---- Security tuning ----------------------------------------
# How long pre-signed download URLs are valid (seconds)
PRESIGN_TTL_SECONDS=300

# bcrypt cost factor — increase for production (12+ recommended)
BCRYPT_ROUNDS=12
